# Helius RPC (free tier at helius.dev)
EXPO_PUBLIC_HELIUS_KEY=your_helius_api_key_here

# Gemini AI (free tier at ai.google.dev) — primary LLM
EXPO_PUBLIC_GEMINI_KEY=your_gemini_api_key_here

# Optional: second Gemini key for quota doubling
EXPO_PUBLIC_GEMINI_KEY_2=your_second_gemini_key_optional

# Groq (free tier at console.groq.com) — LLM fallback
EXPO_PUBLIC_GROQ_KEY=your_groq_api_key_here

# Pinata IPFS (free tier at pinata.cloud)
EXPO_PUBLIC_PINATA_JWT=your_pinata_jwt_here
EXPO_PUBLIC_PINATA_GATEWAY=your-gateway.mypinata.cloud

# Bubblegum cNFT Merkle tree (devnet)
EXPO_PUBLIC_MERKLE_TREE_PUBKEY=your_merkle_tree_pubkey_here

# Solana Attestation Service issuer (devnet)
EXPO_PUBLIC_SAS_ISSUER_PRIVATE_KEY=your_sas_issuer_base58_here
